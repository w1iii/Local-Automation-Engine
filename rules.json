{
    "rules": [
        {
            "ext": ".txt",
            "dest": "~/Documents"
        },
        {
            "ext": ".docx",
            "dest": "~/Documents"
        },
        {
            "ext": ".jpg",
            "dest": "~/Pictures"
        },
        {
            "ext": ".png",
            "dest": "~/Pictures"
        },
        {
            "ext": ".PNG",
            "dest": "~/Pictures"
        },
        {
            "ext": ".svg",
            "dest": "~/Pictures"
        },
        {
            "ext": ".HEIC",
            "dest": "~/Pictures"
        },
        {
            "ext": ".mp3",
            "dest": "~/Music"
        },
        {
            "ext": ".MOV",
            "dest": "~/Movies"
        },
        {
            "ext": ".mp4",
            "dest": "~/Movies"
        },
        {
            "ext": ".MP4",
            "dest": "~/Movies"
        },
        {
            "ext": ".pdf",
            "dest": "~/Documents"
        }
    ]
}
